# FILE PATH: frontend/.env.example

# ===========================
# API ENDPOINTS
# ===========================
REACT_APP_API_URL=http://localhost:5000/api

# ===========================
# PYTHON MICROSERVICES
# ===========================
REACT_APP_PDF_SERVICE_URL=http://localhost:5001
REACT_APP_SMS_SERVICE_URL=http://localhost:5002
REACT_APP_TRANSLATION_SERVICE_URL=http://localhost:5003

# ===========================
# APP CONFIGURATION
# ===========================
REACT_APP_NAME=Smart Medical Diagnosis System
REACT_APP_VERSION=3.0.0
REACT_APP_AI_POWERED=true

# ===========================
# FEATURE FLAGS
# ===========================
REACT_APP_ENABLE_SMS=true
REACT_APP_ENABLE_EMAIL=true
REACT_APP_ENABLE_PDF=true
REACT_APP_ENABLE_TRANSLATION=true